<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- STATE PRESSED -->
    <item android:state_pressed="true">
        <shape>
            <gradient
                android:startColor="#5B4B8A"
                android:endColor="#7C6AE6"
                android:angle="0"/>
            <corners android:radius="30dp"/>
        </shape>
    </item>

    <!-- DEFAULT -->
    <item>
        <shape>
            <gradient
                android:startColor="#6C63FF"
                android:endColor="#8A7BFF"
                android:angle="0"/>
            <corners android:radius="30dp"/>
        </shape>
    </item>

</selector>